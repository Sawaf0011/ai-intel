# Database — Postgres connection details
# POSTGRES_* vars are used by the db service in docker-compose.
# DATABASE_URL uses 'localhost' for host-side access (uv run alembic upgrade head).
# Inside compose, the app and migrate services override it to use 'db' as the hostname.
POSTGRES_USER=aiintel
POSTGRES_PASSWORD=aiintel
POSTGRES_DB=aiintel
DATABASE_URL=postgresql+asyncpg://aiintel:aiintel@localhost:5432/aiintel

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# App
APP_ENV=development
LOG_LEVEL=INFO
